{
  "manifest_version": 3,
  "name": "GitHub Mark as Viewed",
  "version": "1.0.0",
  "description": "Mark GitHub PR files as viewed using glob patterns",
  "permissions": ["activeTab", "storage", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/pull/*/*"],
      "js": ["content.js"]
    }
  ]
}
